{
  "name": "mat-exp-docs",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:mat-exp-docs": "node dist/mat-exp-docs/server/server.mjs",
    "lint": "ng lint",
    "prepare": "husky",
    "commit": "cz",
    "build:lib": "ng build @ngm-dev/mat-exp --configuration production && npm run copy",
    "postbuild:lib": "npm run build --prefix ./projects/ngm-dev/mat-expressive",
    "copy": "cpx README.md dist/ngm-dev/mat-expressive",
    "deploy": "ng deploy --base-href=/mat-expressive/"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.12.0",
  "dependencies": {
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-server": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@angular/ssr": "^21.1.3",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.3.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "angular-cli-ghpages": "^3.1.0",
    "angular-eslint": "21.4.0",
    "cpx": "^1.5.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "lint-staged": "^17.0.8",
    "ng-packagr": "^21.2.0",
    "postcss": "^8.5.3",
    "prettier": "3.9.5",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.2",
    "vitest": "^4.0.8"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,json,css,scss,ts,html,component.html}": [
      "prettier --write"
    ],
    "*.{ts,html}": [
      "eslint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Angular-Material-Dev/mat-exp"
  },
  "bugs": {
    "url": "https://github.com/Angular-Material-Dev/mat-exp/issues"
  },
  "homepage": "https://github.com/Angular-Material-Dev/mat-exp#readme",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
